'''
Day23:- Implementing queue using list
Difficulty:- Medium
Concept:- queue = FIFO (First In First Out)
The first element inserted is the first one to be removed
Basic Operations:
Enqueue → Add element
Dequeue → Remove front element
Peek → Front element
Display → Show queue
Approach
Step 1 : Create an empty list (queue)
Step 2 : Use Enqueue() for push
Step 3 : Use Dequeue() for pop
Step 4 : Use [0] for peek
Step 5 : Use loop for menu-driven program

'''

# Create empty queue (list)
queue = []

# Run infinite loop for menu
while True:
    print("queue Operations") 
    print("1. Enqueue")
    print("2. Dequeue")
    print("3. Peek")
    print("4. Display")
    print("5. Exit")

    # Step 3: Take user choice
    choice = int(input("Enter your choice : "))

    if choice == 1:
        element = int(input("Enter element to enqueue : "))
        queue.append(element)                               # add element to queue
        print("Element enqueue")                            # enqueue operation

   
    elif choice == 2:
        if len(queue) == 0:
            print("queue is empty")
        else:
            removed = queue.pop()                              # remove front element
            print("dequeued element : ", removed)              # dequeue operation


    elif choice == 3:
        if len(queue) == 0:
            print("queue is empty")
        else:
            print("front element : ", queue[0])                  # front element , peek operation


   
    elif choice == 4:
        print("queue : ", queue)                                # display operation


    elif choice == 5:
        print("Exiting program")                                 # exit operation
        break

    else:
        print("Invalid choice")